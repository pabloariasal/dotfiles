#!/bin/zsh

set -e

if command -v paru &>/dev/null; then
    figlet paru
    paru
fi

if command -v flatpak &>/dev/null; then
    figlet flatpak
    flatpak update
fi


if command -v brew &>/dev/null; then
    figlet brew
    brew update && brew upgrade && brew cleanup
fi

figlet antidote
source ${HOME}/.antidote/antidote.zsh
antidote update
