#!/bin/bash

set -e

if [ "$PWD" != "${DOTFILES}" ]; then
    echo "Please run this script from the directory: ${DOTFILES}"
    exit 1
fi

if [ -z "$1" ]; then
    echo "usage: create_new_script <scripts|scripts-i3|scripts-linux> <script_name>"
    exit 1
fi

if [ ! -d "${DOTFILES}/configs/${1}" ]; then
  echo "${DOTFILES}/configs/${1} does not exist."
  exit 1
fi

script="${DOTFILES}/configs/${1}/.local/bin/${2}"

touch "${script}"
chmod +x "$script"
echo '#!/bin/bash' > "$script"
$EDITOR "$script"
