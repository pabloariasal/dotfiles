#!/bin/bash

set -e

SINK_NAME="alsa_output.usb-0b0e_Jabra_Link_380_50C2ED7A49E3-00.analog-stereo"
SOURCE_NAME="alsa_input.usb-0b0e_Jabra_Link_380_50C2ED7A49E3-00.mono-fallback"

pactl set-default-sink "$SINK_NAME"
pactl set-default-source "$SOURCE_NAME"

pactl list short sink-inputs|while read stream; do
    streamId=$(echo $stream|cut '-d ' -f1)
    pactl move-sink-input "$streamId" "$SINK_NAME"
done

notify-send "Headphones ON" -u low -t 2000
echo "🎧headphones" > ~/.sink_pulseaudio
