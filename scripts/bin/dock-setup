#!/bin/bash

echo "Switching to docked setup"

xrandr --output "eDP-1-1" --off --output "DP-1-1-3" --auto

sed -i "s/dpi: 192/dpi: 96/" ${HOME}/.Xresources
xrdb -merge ${HOME}/.Xresources

# change polybar settings
sed -i 's/dpi = 192/dpi = 96/' ${DOTFILES}/polybar/.config/polybar/config
sed -i 's/;4/;2/' ${DOTFILES}/polybar/.config/polybar/config
sed -i 's/height = 26/height = 14/' ${DOTFILES}/polybar/.config/polybar/config

sed -i 's/dpi: 192/dpi: 96/' ${DOTFILES}/rofi/.config/rofi/config.rasi

i3-msg restart

setxkbmap -option compose:rctrl
setxkbmap -option caps:escape
setxkbmap us
xbindkeys

# set the repeat rate of keys
# first number is after how many seconds the key will start repeating
# second number is repetitions per second
# default: 660 25
xset r rate 200 50
