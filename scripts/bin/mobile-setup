#!/bin/bash

echo "Switching to mobile setup"

xrandr --output "DP-1-1-3" --off --output "eDP-1-1" --auto

# change Xresources
sed -i "s/dpi: 96/dpi: 192/" ${HOME}/.Xresources
sed -i "s/size: 16/size: 64/" ${HOME}/.Xresources
xrdb -merge ${HOME}/.Xresources

# change polybar settings
sed -i 's/dpi = 96/dpi = 192/' ${DOTFILES}/polybar/.config/polybar/config
sed -i 's/;2/;4/' ${DOTFILES}/polybar/.config/polybar/config
sed -i 's/height = 14/height = 26/' ${DOTFILES}/polybar/.config/polybar/config

# change rofi settings
sed -i 's/dpi: 96/dpi: 192/' ${DOTFILES}/rofi/.config/rofi/config.rasi

i3-msg restart

setxkbmap -option compose:rctrl
setxkbmap -option caps:escape
setxkbmap us
xbindkeys

# set the repeat rate of keys
# first number is after how many seconds the key will start repeating
# second number is repetitions per second
# default: 660 25
xset r rate 200 50
